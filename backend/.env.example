BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_BASE_URL=https://open-api.bingx.com

# --- Live bot (app/bot) ---
# true = BingX VST (demo/paper trading). Verify the bot on VST before ever
# setting this to false. When true, BINGX_API_KEY/SECRET above must be a
# VST-issued demo key (generated separately from your live key in the BingX
# VST dashboard); when false, they must be your real account's live key.
BINGX_USE_VST=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

BOT_SYMBOL=BTC-USDT
BOT_STATE_DIR=state
